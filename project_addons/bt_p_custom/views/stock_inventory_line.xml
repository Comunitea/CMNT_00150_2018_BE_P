<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="stock_inventory_line_tree2" model="ir.ui.view">
        <field name="name">stock_inventory_line_tree2_inherit</field>
        <field name="model">stock.inventory.line</field>
        <field name="inherit_id" ref="stock.stock_inventory_line_tree2"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='prod_lot_id']" position="after">
                <field name="use_date" groups="stock.group_production_lot"/>
            </xpath>
        </field>
    </record>

    <record id="view_inventory_form" model="ir.ui.view">
        <field name="name">view_inventory_form_inherit</field>
        <field name="model">stock.inventory</field>
        <field name="inherit_id" ref="stock.view_inventory_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='prod_lot_id']" position="after">
                <field name="use_date" groups="stock.group_production_lot"/>
            </xpath>
        </field>
    </record>

</odoo>
